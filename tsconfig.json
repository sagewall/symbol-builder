{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*",
    "./node_modules/@arcgis/coding-components/dist/types/react.d.ts",
    "./node_modules/@esri/calcite-components/dist/types/react.d.ts",
    "./node_modules/@arcgis/map-components/dist/types/react.d.ts",
    "./types.d.ts",
    "./worker-configuration.d.ts"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}